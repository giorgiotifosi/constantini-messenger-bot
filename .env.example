# Meta Page access token (Messenger → Settings → Access Tokens)
PAGE_ACCESS_TOKEN=

# Custom string you enter in Meta webhook "Verify Token" field
VERIFY_TOKEN=

# --- Optional: limit photos to specific ads (chat open). Not required for button tap. ---
# MESSENGER_AD_IDS=123456789012345
# MESSENGER_AD_REF=kitchen30
# MESSENGER_AD_TITLE_KEYWORD=სამზარეულო
# MESSENGER_AD_SEND_ON_ALL=true
# MESSENGER_AD_GREETING_ECHO=true

# Chat builder button label (default: სამზარეულო)
# KITCHEN_BUTTON_LABEL=სამზარეულო

SAVED_TEMPLATE_LABEL=სამზარეულო bot 30 ფოტო

# MESSENGER_SEND_ON_ANY_MESSAGE=true
# KITCHEN_TEXT_TRIGGER=სამზარეულო

# album = all photos in one message (default); sequential = one photo per message
# KITCHEN_SEND_MODE=sequential

KITCHEN_IMAGE_URLS=

# Optional: Vercel KV / Upstash (stops duplicate sends across serverless instances)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
