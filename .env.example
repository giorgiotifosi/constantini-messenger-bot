# Meta Page access token (Messenger → Settings → Access Tokens)
PAGE_ACCESS_TOKEN=

# Custom string you enter in Meta webhook "Verify Token" field
VERIFY_TOKEN=

# Public HTTPS URLs for the 3 kitchen images (required for "სამზარეულო" reply)
KITCHEN_IMAGE_URL_1=
KITCHEN_IMAGE_URL_2=
KITCHEN_IMAGE_URL_3=
