# Meta Page access token (Messenger → Settings → Access Tokens)
PAGE_ACCESS_TOKEN=

# Custom string you enter in Meta webhook "Verify Token" field
VERIFY_TOKEN=

# Meta Inbox label / Ads Chat builder template name
SAVED_TEMPLATE_LABEL=სამზარეულო bot 30 ფოტო

# Click-to-Messenger ad — ref optional; any ADS click sends album by default
MESSENGER_AD_REF=kitchen30
# MESSENGER_AD_SEND_ON_ALL=true
# MESSENGER_AD_STRICT=true
# Subscribe to message_echoes in Meta app for Chat builder greeting

# Optional: text Page sends with saved reply (defaults to SAVED_TEMPLATE_LABEL)
# SAVED_TEMPLATE_ECHO_TEXT=

# Optional: also send when customer types this (leave empty to disable)
# KITCHEN_TEXT_TRIGGER=სამზარეულო

# Kitchen album (1–30 images, one Messenger message)
# Comma- or newline-separated HTTPS URLs, or JSON array:
# KITCHEN_IMAGE_URLS=https://example.com/1.jpg,https://example.com/2.jpg
KITCHEN_IMAGE_URLS=

# Optional: instead of KITCHEN_IMAGE_URLS, set numbered vars (up to 30)
# KITCHEN_IMAGE_URL_1=
# KITCHEN_IMAGE_URL_2=
