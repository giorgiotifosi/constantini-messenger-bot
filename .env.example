# Meta Page access token (Messenger → Settings → Access Tokens)
PAGE_ACCESS_TOKEN=

# Custom string you enter in Meta webhook "Verify Token" field
VERIFY_TOKEN=

# --- Allowed Click-to-Messenger ads (required) ---
# Comma-separated Facebook ad IDs from Ads Manager URL (act=...&selected_ad_ids=THIS_ID)
MESSENGER_AD_IDS=123456789012345

# Optional: same ref in ad Advanced settings (if available)
MESSENGER_AD_REF=kitchen30

# Optional: match ad_title containing this word
# MESSENGER_AD_TITLE_KEYWORD=სამზარეულო

# Send on ALL ads (not recommended): MESSENGER_AD_SEND_ON_ALL=true
# Send on greeting echo without ad_id filter: MESSENGER_AD_GREETING_ECHO=true

SAVED_TEMPLATE_LABEL=სამზარეულო bot 30 ფოტო

# MESSENGER_SEND_ON_ANY_MESSAGE=true
# KITCHEN_TEXT_TRIGGER=სამზარეულო

# sequential = one photo per message (default); album = all in one message
# KITCHEN_SEND_MODE=album

KITCHEN_IMAGE_URLS=

# Optional: Vercel KV / Upstash (stops duplicate sends across serverless instances)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
